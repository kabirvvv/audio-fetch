<?xml version="1.0" encoding="utf-8"?>
<!--
  lyrics_sheet.xml
  Drop this as a direct child of your root ConstraintLayout in activity_main.xml
  (same level as playerContainer, libraryContainer, settingsPanel etc.)

  Initial state: visibility="gone", translationY = full screen height (set in code)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/lyricsSheet"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A0A0A"
    android:visibility="gone"
    android:elevation="12dp">

    <!-- Back button -->
    <ImageButton
        android:id="@+id/lyricsBackBtn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back"
        android:tint="#99FFFFFF"
        android:contentDescription="Close lyrics"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Track title at top -->
    <TextView
        android:id="@+id/lyricsTitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="64dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#80FFFFFF"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@id/lyricsBackBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/lyricsBackBtn"
        app:layout_constraintTop_toTopOf="@id/lyricsBackBtn" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/lyricsLoadingIndicator"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Lyrics list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/lyricsRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingTop="80dp"
        android:paddingBottom="120dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lyricsBackBtn" />

</androidx.constraintlayout.widget.ConstraintLayout>
