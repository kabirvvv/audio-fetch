<?xml version="1.0" encoding="utf-8"?>
<!--
    Home shelf card  —  140 dp wide, height wraps content
    Used by HomeCardAdapter in every horizontal shelf row.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="140dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="0dp"
    android:layout_marginEnd="12dp">

    <!--  Square album art — 140 × 140 dp, rounded 8 dp  -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/homeCardArt"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/RoundedCorner8" />

    <!--  Title: 13 sp, white, single line  -->
    <TextView
        android:id="@+id/homeCardTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium" />

    <!--  Artist: 11 sp, 50% white, single line  -->
    <TextView
        android:id="@+id/homeCardArtist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#80FFFFFF"
        android:textSize="11sp" />

</LinearLayout>
